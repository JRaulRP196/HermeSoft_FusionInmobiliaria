@{
    ViewBag.Title = "Estadísticas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">

    <!-- ==== OPCIONES ==== -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">

                    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">

                        <h5 class="mb-0 fw-semibold">Opciones</h5>

                        <form id="formFechas" class="ms-md-auto" novalidate>

                            <div class="row g-2 align-items-end">

                                <div class="col-12 col-md-auto">
                                    <label class="fw-semibold">De:</label>
                                    <input type="date" id="fechaInicio" name="fechaDe"
                                           class="form-control form-control-sm" required>
                                </div>

                                <div class="col-12 col-md-auto">
                                    <label class="fw-semibold">A:</label>
                                    <input type="date" id="fechaFinal" name="fechaA"
                                           class="form-control form-control-sm" required>
                                </div>

                                <div class="col-12 col-md-auto">
                                    <button class="btn btn-primary btn-sm w-100" id="filtro">
                                        <i class="bi bi-funnel"></i> Filtrar
                                    </button>
                                </div>

                            </div>

                        </form>

                    </div>

                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0 rounded-4">

                <div class="card-body d-flex justify-content-center gap-3">

                    <div class="col-md-3">
                        <div class="mb-0 card bg-light border-0">
                            <div class="card-body text-center">
                                <h5 class="card-title">Pagos al Día</h5>
                                <p class="card-text display-6 fw-bold" id="pagosAlDia">N/A</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="mb-0 card bg-light border-0">
                            <div class="card-body text-center">
                                <h5 class="card-title">Pagos Pendientes</h5>
                                <p class="card-text display-6 fw-bold" id="pagosPendientes">N/A</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="mb-0 card bg-light border-0">
                            <div class="card-body text-center">
                                <h5 class="card-title">Pagos Atrasados</h5>
                                <p class="card-text display-6 fw-bold" id="pagosAtrasados">N/A</p>
                            </div>
                        </div>
                    </div>

                </div>

            </div>
        </div>
    </div>

    <!-- ==== MENSAJE ERROR ==== -->
    @if (TempData["MensajeErrorFiltro"] != null)
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="alert alert-danger">
                    @TempData["MensajeErrorFiltro"]
                </div>
            </div>
        </div>
    }

    <!-- ==== ESTADÍSTICA ==== -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0 rounded-4">

                <div class="card-header border-0 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 px-4 pt-4">

                    <h5 class="fw-semibold mb-0">Estadística</h5>
                </div>

                <div class="card-body px-2 px-md-4 pb-4">
                    <div id="column_stacked" class="apex-charts w-100"></div>
                </div>

                <div class="card-header border-0 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 px-4 pt-4" id="opciones">
                    <button class="btn btn-outline-secondary btn-sm w-100 w-md-auto" id="descargar">
                        <i class="bi bi-download"></i> Descargar
                    </button>
                </div>

            </div>
        </div>
    </div>



</div>

@section scripts {
    <script src="~/assets/js/pages/form-validation.init.js"></script>
    <script src="~/assets/libs/apexcharts/apexcharts.min.js"></script>
    <script src="~/assets/js/estadisticas.js"></script>
    <script src="~/assets/js/app.js"></script>
}