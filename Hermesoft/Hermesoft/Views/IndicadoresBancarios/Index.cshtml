@model IEnumerable<HermeSoft_Fusion.Models.Banco.IndicadoresBancarios>

@{
    ViewBag.Title = "Referencias Económicas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card border-0 shadow-sm rounded-4 p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold mb-0">Indicadores</h4>
    </div>
    <div class="row">
        @foreach(var r in Model)
        {
            <div class="col-md-3 mb-3">
                <div class="card bg-light border-0">
                    <div class="card-body text-center">
                        <h5 class="card-title">@r.Nombre</h5>
                        <p class="card-text display-6 fw-bold">@r.PorcSeguro %</p>
                    </div>
                </div>
            </div>
        }
    </div>
    <small class="text-muted">Valores obtenidos desde el BCCR. No editables manualmente.</small>
</div>