@model HermeSoft_Fusion.Models.Primas

@{
    ViewData["Title"] = "Detalle de Prima";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-3 py-md-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-3 p-md-4">

            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold mb-0">Detalle de Prima</h3>

                <a asp-controller="Estadistica" asp-action="Primas"
                   class="btn btn-light border d-flex align-items-center gap-2">
                    <i class="fas fa-arrow-left"></i>
                    Volver
                </a>
            </div>
            <div class="row g-3 mb-4">

                <div class="col-12 col-md-6 col-lg-4">
                    <div class="p-3 border rounded-3 h-100 bg-light">
                        <small class="text-muted d-block">ID Prima</small>
                        <strong>@Model.IdPrima</strong>
                    </div>
                </div>

                <div class="col-12 col-md-6 col-lg-4">
                    <div class="p-3 border rounded-3 h-100 bg-light">
                        <small class="text-muted d-block">Cliente</small>
                        <strong class="text-break">@Model.CorreoCliente</strong>
                    </div>
                </div>

                <div class="col-12 col-md-6 col-lg-4">
                    <div class="p-3 border rounded-3 h-100 bg-light">
                        <small class="text-muted d-block">Número de contrato</small>
                        <strong>
                            @(Model.Venta != null ? Model.Venta.NumContrato.ToString() : "No disponible")
                        </strong>
                    </div>
                </div>

                <div class="col-6 col-md-3">
                    <div class="p-3 border rounded-3 h-100 bg-light">
                        <small class="text-muted d-block">Código Lote</small>
                        <strong>@Model.CodLote</strong>
                    </div>
                </div>

                <div class="col-6 col-md-3">
                    <div class="p-3 border rounded-3 h-100 bg-light">
                        <small class="text-muted d-block">Asignado</small>
                        <strong>@(Model.Asignado ? "Sí" : "No")</strong>
                    </div>
                </div>

            </div>

            <!-- Tabla -->
            <div class="card border-0 bg-white rounded-4">
                <div class="card-body p-2 p-md-3">
                    <h4 class="fw-bold mb-3">Plan completo de prima</h4>

                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-nowrap">Fecha</th>
                                    <th class="text-nowrap">Monto</th>
                                    <th class="text-nowrap">Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.DesglosesPrimas != null && Model.DesglosesPrimas.Any())
                                {
                                    @foreach (var item in Model.DesglosesPrimas.OrderBy(x => x.FechaCobro))
                                    {
                                        <tr>
                                            <td class="text-nowrap">
                                                @item.FechaCobro.ToString("dd/MM/yyyy")
                                            </td>

                                            <td class="text-nowrap">
                                                ₡@item.Monto.ToString("N2")
                                            </td>

                                            <td>
                                                @if (item.Estado == "Pendiente")
                                                {
                                                    <span class="badge bg-warning text-dark rounded-pill px-3 py-2 d-block d-md-inline text-center">
                                                        @item.Estado
                                                    </span>
                                                }
                                                else if (item.Estado == "Terminado" || item.Estado == "Pagado")
                                                {
                                                    <span class="badge bg-success rounded-pill px-3 py-2 d-block d-md-inline text-center">
                                                        @item.Estado
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary rounded-pill px-3 py-2 d-block d-md-inline text-center">
                                                        @item.Estado
                                                    </span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="3" class="text-center">
                                            No hay desgloses registrados para esta prima.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>