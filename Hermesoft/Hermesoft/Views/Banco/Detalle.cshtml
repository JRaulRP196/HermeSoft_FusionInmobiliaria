@using HermeSoft_Fusion.Models.Banco
@model Banco
@{
    ViewBag.Title = "Bancos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-3 py-md-4 px-2 px-md-4">

    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger">
            @TempData["MensajeError"]
        </div>
    }

    <!-- HEADER -->
    <div class="card border-0 shadow-sm rounded-4 mb-4 p-3 p-md-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
            <h4 class="mb-0 fw-bold">@Model.Nombre</h4>

            <div class="d-flex flex-column flex-sm-row gap-2 w-100 w-md-auto">
                <a class="btn btn-outline-primary w-100 w-sm-auto rounded-pill"
                   asp-action="Editar" asp-route-id="@Model.IdBanco">
                    <i class="fas fa-edit me-2"></i> Editar
                </a>

                <a asp-action="Index"
                   class="btn btn-light border w-100 w-sm-auto rounded-pill">
                    <i class="fas fa-arrow-left me-2"></i> Volver
                </a>
            </div>
        </div>
    </div>

    <!-- LOGO + INFO -->
    <div class="row g-3 g-md-4 mb-4">

        <!-- LOGO -->
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 p-md-4 h-100 d-flex align-items-center justify-content-center">
                @if (!string.IsNullOrEmpty(Model.Logo))
                {
                    <img src="@Model.Logo" class="img-fluid" style="max-height: 220px; object-fit: contain;" />
                }
                else
                {
                    <div class="text-center">
                        <i class="ri-bank-fill" style="font-size: 4rem; color: #6c757d;"></i>
                        <div class="text-muted">Sin logo</div>
                    </div>
                }
            </div>
        </div>

        <!-- INFO -->
        <div class="col-12 col-md-8">
            <div class="card border-0 shadow-sm rounded-4 p-3 p-md-4 h-100">
                <h5 class="fw-bold mb-3">Información General</h5>

                <div class="d-flex flex-column gap-2">

                    <div class="d-flex flex-column flex-md-row">
                        <div class="text-muted fw-semibold col-md-4">Nombre:</div>
                        <div>@Model.Nombre</div>
                    </div>

                    <div class="d-flex flex-column flex-md-row">
                        <div class="text-muted fw-semibold col-md-4">Enlace:</div>
                        <div>
                            <a href="@Model.Enlace" target="_blank" class="text-break">@Model.Enlace</a>
                        </div>
                    </div>

                    <div class="d-flex flex-column flex-md-row">
                        <div class="text-muted fw-semibold col-md-4">Plazo Máximo:</div>
                        <div>@Model.MaxCredito años</div>
                    </div>

                    <div class="d-flex flex-column flex-md-row">
                        <div class="text-muted fw-semibold col-md-4">Comisión:</div>
                        <div>@Model.Comision%</div>
                    </div>

                    <div class="d-flex flex-column flex-md-row">
                        <div class="text-muted fw-semibold col-md-4">Honorarios:</div>
                        <div>@Model.HonorarioAbogado%</div>
                    </div>

                    <div class="d-flex flex-column flex-md-row">
                        <div class="text-muted fw-semibold col-md-4">Tipo Cambio:</div>
                        <div>@Model.TipoCambio.Cambio</div>
                    </div>

                </div>
            </div>
        </div>

    </div>

    <!-- ENDEUDAMIENTO -->
    <div class="card border-0 shadow-sm rounded-4 p-3 p-md-4 mb-4">
        <h5 class="fw-bold mb-3">Endeudamiento Máximo</h5>

        @if (Model.EndeudamientoMaximos != null)
        {
            <div class="row g-3">
                @foreach (var endeu in Model.EndeudamientoMaximos)
                {
                    <div class="col-6 col-md-3">
                        <div class="card bg-light border-0 h-100">
                            <div class="card-body text-center">
                                <h6>@endeu.TipoAsalariado?.Nombre</h6>
                                <div class="fw-bold fs-4">
                                    @(endeu.PorcEndeudamiento.ToString("0.##"))%
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-info">Sin datos</div>
        }
    </div> 

    <!-- SEGUROS -->
    <div class="card border-0 shadow-sm rounded-4 p-3 p-md-4 mb-4">
        <h5 class="fw-bold mb-3">Seguros</h5>

        @if (Model.SeguroBancos != null)
        {
            <div class="row g-3">
                @foreach (var seguro in Model.SeguroBancos)
                {
                    <div class="col-12 col-md-6">
                        <div class="card bg-light border-0 h-100">
                            <div class="card-body text-center">
                                <h6>@seguro.Seguro?.Nombre</h6>
                                <div class="fw-bold fs-4">
                                    @(seguro.PorcSeguro.ToString("0.##"))%
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-info">Sin seguros</div>
        }
    </div>

    <!-- ESCENARIOS -->
    @if (Model.EscenariosTasaInteres != null)
    {
        @foreach (var escenario in Model.EscenariosTasaInteres)
        {
            <div class="card border-0 shadow-sm rounded-4 p-3 p-md-4 mb-4">
                <h5 class="fw-bold mb-3">
                    Escenario: @escenario.Nombre
                </h5>

                <div class="table-responsive">
                    <table class="table table-hover align-middle text-nowrap">
                        <thead class="table-dark">
                            <tr>
                                <th>Plazo</th>
                                <th>% Adicional</th>
                                <th>Indicador</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var plazo in escenario.PlazosEscenarios)
                            {
                                <tr>
                                    <td>@plazo.Plazo</td>
                                    <td>@plazo.PorcAdicional%</td>
                                    <td>@plazo.Indicador.Nombre</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info">No hay escenarios registrados.</div>
    }

</div>