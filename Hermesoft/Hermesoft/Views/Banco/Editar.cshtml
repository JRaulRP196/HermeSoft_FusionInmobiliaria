@using HermeSoft_Fusion.Models.Banco
@{
    ViewBag.Title = "Bancos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model Banco
<div class="row">
    <div class="col">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Edicion de Bancos</h4>
                <p class="card-title-desc">
                    En este apartado se podra editar el banco seleccionado.
                </p>
                <form class="needs-validation" asp-action="Editar" method="post" enctype="multipart/form-data" novalidate>

                    <div class="stepper-wrapper mb-5">
                        <div class="stepper-item active" data-step="1">
                            <div class="step-counter">1</div>
                            <div class="step-name">Datos Generales</div>
                        </div>

                        <div class="stepper-item" data-step="2">
                            <div class="step-counter">2</div>
                            <div class="step-name">Porcentajes</div>
                        </div>

                        <div class="stepper-item" data-step="3">
                            <div class="step-counter">3</div>
                            <div class="step-name">Escenarios</div>
                        </div>

                        <div class="stepper-item" data-step="4">
                            <div class="step-counter">4</div>
                            <div class="step-name">Confirmar</div>
                        </div>
                    </div>


                    <div class="step-content" data-step="1">

                        <input type="hidden" asp-for="IdTipoCambio" value="@ViewBag.TipoCambio.IdTipoCambio" />

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="validationCustom01" class="form-label">Nombre del Banco</label>
                                    <input type="hidden" asp-for="IdBanco" />
                                    <input type="text" class="form-control" id="Nombre"
                                           placeholder="Nombre del Banco" required asp-for="Nombre">
                                    <div class="valid-feedback">
                                        Excelente!
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="validationCustom02" class="form-label">Enlace Web del Banco</label>
                                    <input type="text" class="form-control" id="Enlace"
                                           placeholder="Enlace Web del Banco" asp-for="Enlace" required>
                                    <div class="valid-feedback">
                                        Excelente!
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label for="validationCustom03" class="form-label">Logo del Banco</label>
                                    <div class="input-group">
                                        <input type="file" class="form-control" id="validationCustom03" name="LogoFile" asp-for="Logo">
                                    </div>
                                    <div class="invalid-feedback">
                                        Ingrese un valor valido.
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label for="validationCustom04" class="form-label">Plazo Maximo de Credito</label>
                                    <input type="number" class="form-control" id="MaxCredito"
                                           placeholder="Plazo Maximo de Credito en Anos" asp-for="MaxCredito" required>
                                    <div class="invalid-feedback">
                                        Ingrese un valor valido.
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label for="validationCustom05" class="form-label">Comision Bancaria</label>
                                    <input type="number" class="form-control" id="Comision"
                                           placeholder="%" asp-for="Comision" required>
                                    <div class="invalid-feedback">
                                        Ingrese un valor valido.
                                    </div>
                                </div>
                            </div>

                            <div class="text-end mt-3">
                                <button type="button" class="btn btn-primary next-btn">
                                    Siguiente <i class="bi bi-arrow-right"></i>
                                </button>
                            </div>

                        </div>

                    </div>

                    <div class="step-content d-none" data-step="2">
                        <label for="validationCustom05" class="form-label">Porcentaje de Endeudamiento Maximo</label>
                        <div class="row">
                            @for (int i = 0; i < Model.EndeudamientoMaximos.Count(); i++)
                            {
                                <div class="col-md-3">
                                    <div class="mb-3">
                                        <div class="input-group">
                                            <div class="input-group-text">@Model.EndeudamientoMaximos[i].TipoAsalariado.Nombre</div>
                                            <input type="hidden" asp-for="@Model.EndeudamientoMaximos[i].IdEndeudamiento" />
                                            <input type="hidden" asp-for="@Model.EndeudamientoMaximos[i].IdTipoAsalariado" />
                                            <input type="hidden" asp-for="@Model.EndeudamientoMaximos[i].IdBanco" />
                                            <input type="number" class="form-control" placeholder="%" asp-for="@Model.EndeudamientoMaximos[i].PorcEndeudamiento" required>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="row">
                            @for (int i = 0; i < Model.SeguroBancos.Count(); i++)
                            {
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Seguro de @Model.SeguroBancos[i].Seguro.Nombre</label>
                                        <input type="hidden" asp-for="@Model.SeguroBancos[i].IdSeguroBanco" />
                                        <input type="hidden" asp-for="@Model.SeguroBancos[i].IdSeguro" />
                                        <input type="hidden" asp-for="@Model.SeguroBancos[i].IdBanco" />
                                        <input type="number" class="form-control" placeholder="%" asp-for="@Model.SeguroBancos[i].PorcSeguro" required>
                                        <div class="valid-feedback">
                                            Excelente!
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="col">
                            <div class="mb-3">
                                <label class="form-label">Gastos de Honorarios de Abogados</label>
                                <input type="number" class="form-control" placeholder="%" asp-for="HonorarioAbogado" required>
                                <div class="valid-feedback">
                                    Excelente!
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-3">
                            <button type="button" class="btn btn-secondary prev-btn">
                                <i class="bi bi-arrow-left"></i> Anterior
                            </button>
                            <button type="button" class="btn btn-primary next-btn">
                                Siguiente <i class="bi bi-arrow-right"></i>
                            </button>
                        </div>
                    </div>

                    <div class="step-content d-none" data-step="3">
                        <label class="form-label">Tasas de Interes</label> <br />
                        <label class="form-label">Escenarios: </label>
                        <button type="button" class="btn btn-primary" id="addEscenario">+</button>

                        <div id="listaEscenarios">

                            <div class="row escenarios">
                                <div class="col">
                                    <div class="card card-body">
                                        <h3 class="card-title">Escenario #1</h3>

                                        <div class="row">
                                            <div class="col-md-9">
                                                <label class="form-label">Tipo de Tasa de Interes</label>
                                                <select class="form-select tipoInteres" required asp-for="EscenariosTasaInteres[0].IdTasaInteres">
                                                    @foreach (TasaInteres tasa in ViewBag.TasaInteres)
                                                    {
                                                        <option value="@tasa.IdTasaInteres">@tasa.Nombre</option>
                                                    }
                                                </select>
                                                <input type="hidden" asp-for="EscenariosTasaInteres[0].IdBanco" />
                                                <input type="hidden" asp-for="EscenariosTasaInteres[0].IdEscenario" />
                                            </div>
                                            <div class="col-md-3">
                                                <label class="form-label">Nombre del Escenario</label>
                                                <input type="text" class="form-control" placeholder="Nombre" asp-for="EscenariosTasaInteres[0].Nombre" required>
                                            </div>
                                        </div>

                                        <br />


                                        @for (int i = 0; i < Model.EscenariosTasaInteres[0].PlazosEscenarios.Count(); i++)
                                        {
                                            <div class="row inputsEscenario">
                                                <div class="col-md-3">
                                                    <div class="mb-3">
                                                        <label class="form-label">Plazo de Duracion</label>
                                                        <input type="number" class="form-control" placeholder="Meses" asp-for="@Model.EscenariosTasaInteres[0].PlazosEscenarios[i].Plazo" required>
                                                        <input type="hidden" asp-for="@Model.EscenariosTasaInteres[0].PlazosEscenarios[i].IdEscenario" />
                                                        <input type="hidden" asp-for="@Model.EscenariosTasaInteres[0].PlazosEscenarios[i].IdPlazoEscenario" />
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <div class="mb-3">
                                                        <label class="form-label">Porcentaje Adicional del Banco</label>
                                                        <input type="number" class="form-control" placeholder="%" asp-for="@Model.EscenariosTasaInteres[0].PlazosEscenarios[i].PorcAdicional" required>
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <div class="mb-3">
                                                        <label class="form-label d-flex align-items-center gap-1">
                                                            <span>Indicador Bancario</span>
                                                            <button type="button"
                                                                    class="btn btn-link p-0 text-info indicador-popover-trigger"
                                                                    data-bs-toggle="popover"
                                                                    data-bs-trigger="click"
                                                                    data-bs-placement="top"
                                                                    data-bs-html="true"
                                                                    title="Información"
                                                                    data-bs-content="Si desea más información puede hacer click <a href='../../IndicadoresBancarios/Index' target='_blank'>aquí</a>.">
                                                                <i class="ri-information-line"></i>
                                                            </button>
                                                        </label>
                                                        <select class="form-select" asp-for="@Model.EscenariosTasaInteres[0].PlazosEscenarios[i].IdIndicador" required>
                                                            @foreach (IndicadoresBancarios indicador in ViewBag.IndicadoresBancarios)
                                                            {
                                                                <option value="@indicador.IdIndicador">@indicador.Nombre</option>
                                                            }
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                        }


                                        <div class="button-items botonesEscalonada"></div>
                                    </div>
                                </div>
                            </div>

                            @if (Model.EscenariosTasaInteres.Count() >= 2)
                            {
                                @for (int i = 1; i < Model.EscenariosTasaInteres.Count(); i++)
                                {
                                    <div class="row escenarios">
                                        <div class="col">
                                            <div class="card card-body">
                                                <h3 class="card-title">Escenario #@(i + 1)</h3>
                                                <button type="button" class="btn btn-danger waves-effect waves-light deleteEscenario">
                                                    <i class="ri-close-line align-middle me-2"></i> Eliminar Escenario
                                                </button>
                                                <div class="row">
                                                    <div class="col-md-9">
                                                        <label class="form-label">Tipo de Tasa de Interes</label>
                                                        <select class="form-select tipoInteres" asp-for="EscenariosTasaInteres[i].IdTasaInteres" required>
                                                            @foreach (TasaInteres tasa in ViewBag.TasaInteres)
                                                            {
                                                                <option value="@tasa.IdTasaInteres">@tasa.Nombre</option>
                                                            }
                                                        </select>
                                                        <input type="hidden" asp-for="@Model.EscenariosTasaInteres[i].IdBanco" />
                                                        <input type="hidden" asp-for="@Model.EscenariosTasaInteres[i].IdEscenario" />
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label class="form-label">Nombre del Escenario</label>
                                                        <input type="text" class="form-control" placeholder="Nombre" asp-for="EscenariosTasaInteres[i].Nombre" required>
                                                    </div>
                                                </div>
                                                <br />

                                                @for (int j = 0; j < Model.EscenariosTasaInteres[i].PlazosEscenarios.Count(); j++)
                                                {
                                                    <div class="row inputsEscenario">
                                                        <div class="col-md-3">
                                                            <div class="mb-3">
                                                                <label class="form-label">Plazo de Duracion</label>
                                                                <input type="number" class="form-control" placeholder="Meses" asp-for="@Model.EscenariosTasaInteres[i].PlazosEscenarios[j].Plazo" required>
                                                                <input type="hidden" asp-for="@Model.EscenariosTasaInteres[i].PlazosEscenarios[j].IdEscenario" />
                                                                <input type="hidden" asp-for="@Model.EscenariosTasaInteres[i].PlazosEscenarios[j].IdPlazoEscenario" />
                                                            </div>
                                                        </div>
                                                        <div class="col-md-3">
                                                            <div class="mb-3">
                                                                <label class="form-label">Porcentaje Adicional del Banco</label>
                                                                <input type="number" class="form-control" placeholder="%" asp-for="@Model.EscenariosTasaInteres[i].PlazosEscenarios[j].PorcAdicional" required>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-3">
                                                            <div class="mb-3">
                                                                <label class="form-label d-flex align-items-center gap-1">
                                                                    <span>Indicador Bancario</span>
                                                                    <button type="button"
                                                                            class="btn btn-link p-0 text-info indicador-popover-trigger"
                                                                            data-bs-toggle="popover"
                                                                            data-bs-trigger="click"
                                                                            data-bs-placement="top"
                                                                            data-bs-html="true"
                                                                            title="Información"
                                                                            data-bs-content="Si desea más información puede hacer click <a href='../../IndicadoresBancarios/Index' target='_blank'>aquí</a>.">
                                                                        <i class="ri-information-line"></i>
                                                                    </button>
                                                                </label>
                                                                <select class="form-select" asp-for="@Model.EscenariosTasaInteres[i].PlazosEscenarios[j].IdIndicador" required>
                                                                    @foreach (IndicadoresBancarios indicador in ViewBag.IndicadoresBancarios)
                                                                    {
                                                                        <option value="@indicador.IdIndicador">@indicador.Nombre</option>
                                                                    }
                                                                </select>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                                <div class="button-items botonesEscalonada"></div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }

                        </div>
                        <div class="d-flex justify-content-between mt-3">
                            <button type="button" class="btn btn-secondary prev-btn">
                                <i class="bi bi-arrow-left"></i> Anterior
                            </button>
                            <button type="button" class="btn btn-primary next-btn">
                                Siguiente <i class="bi bi-arrow-right"></i>
                            </button>
                        </div>
                    </div>

                    <div class="step-content d-none" data-step="4">

                        <div class="row align-items-end mt-4">
                            <div id="resumenBanco" class="card border-0 shadow-sm rounded-4 p-4"></div>

                            <div class="col-md-12 text-end">
                                <button type="button" class="btn btn-secondary prev-btn">
                                    <i class="bi bi-arrow-left"></i> Anterior
                                </button>
                                <button class="btn btn-primary" type="submit"><i class="bi bi-save"></i> Guardar</button>
                                <a class="btn btn-danger" asp-action="Index"><i class="bi bi-x-circle"></i> Cancelar</a>
                            </div>
                        </div>

                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

<div class="row escenarios" id="escenario-template" style="display:none;">
    <div class="col">
        <div class="card card-body">
            <h3 class="card-title">Escenario #x</h3>

            <button type="button"
                    class="btn btn-danger deleteEscenario">
                Eliminar Escenario
            </button>

            <div class="row">
                <div class="col-md-9">
                    <label class="form-label">Tipo de Tasa de Interés</label>
                    <select class="form-select tipoInteres"
                            name="EscenariosTasaInteres[0].IdTasaInteres" required>
                        @foreach (TasaInteres tasa in ViewBag.TasaInteres)
                        {
                            <option value="@tasa.IdTasaInteres">@tasa.Nombre</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Nombre del Escenario</label>
                    <input type="text" class="form-control"
                           name="EscenariosTasaInteres[0].Nombre" placeholder="Nombre" required>
                    <input type="hidden" name="EscenariosTasaInteres[0].IdBanco" value="@Model.IdBanco" />
                    <input type="hidden" name="EscenariosTasaInteres[0].IdEscenario" />
                </div>
            </div>

            <br />

            <div class="row inputsEscenario">
                <input type="hidden" name="EscenariosTasaInteres[0].PlazosEscenarios[0].IdPlazoEscenario" />

                <div class="col-md-3">
                    <div class="mb-3">
                        <label class="form-label">Plazo de Duración</label>
                        <input type="number" class="form-control" placeholder="Meses" value=""
                               name="EscenariosTasaInteres[0].PlazosEscenarios[0].Plazo" required>

                    </div>
                </div>

                <div class="col-md-3">
                    <div class="mb-3">
                        <label class="form-label">Porcentaje Adicional del Banco</label>
                        <input type="number" class="form-control" placeholder="%" value=""
                               name="EscenariosTasaInteres[0].PlazosEscenarios[0].PorcAdicional" required>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="mb-3">
                        <label class="form-label d-flex align-items-center gap-1">
                            <span>Indicador Bancario</span>
                            <button type="button"
                                    class="btn btn-link p-0 text-info indicador-popover-trigger"
                                    data-bs-toggle="popover"
                                    data-bs-trigger="click"
                                    data-bs-placement="top"
                                    data-bs-html="true"
                                    title="Información"
                                    data-bs-content="Si desea más información puede hacer click <a href='../../IndicadoresBancarios/Index' target='_blank'>aquí</a>.">
                                <i class="ri-information-line"></i>
                            </button>
                        </label>
                        <select class="form-select"
                                name="EscenariosTasaInteres[0].PlazosEscenarios[0].IdIndicador" required>
                            @foreach (IndicadoresBancarios indicador in ViewBag.IndicadoresBancarios)
                            {
                                <option value="@indicador.IdIndicador">@indicador.Nombre</option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="button-items botonesEscalonada"></div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/assets/js/stepper.js"></script>
    <script src="~/assets/libs/parsleyjs/parsley.min.js"></script>
    <script src="~/assets/js/pages/form-validation.init.js"></script>
    <script src="~/assets/js/escenariosBanco.js"></script>
    <script src="~/assets/js/resumenBanco.js"></script>
}
