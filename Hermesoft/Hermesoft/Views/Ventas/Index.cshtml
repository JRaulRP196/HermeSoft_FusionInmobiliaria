@{
    ViewBag.Title = "Historial de Ventas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model List<HermeSoft_Fusion.Models.Venta>

@{
    var condominios = ViewBag.Condominios as List<HermeSoft_Fusion.Models.Servicios.Condominio>;
}

<div class="container-fluid py-3 py-md-4">

    <!-- MENSAJES -->
    <div class="card shadow-sm mb-3 border-0">
        @if (TempData["MensajeErrorEmail"] != null)
        {
            <div class="alert alert-danger m-2">@TempData["MensajeErrorEmail"]</div>
        }

        @if (TempData["MensajeExitoEmail"] != null)
        {
            <div class="alert alert-success m-2">
                <p class="mb-0">@TempData["MensajeExitoEmail"]</p>
            </div>
        }
    </div>

    <div class="card border-0 shadow-sm rounded-4 p-3 p-md-4">

        <!-- FILTROS -->
        <form asp-action="Index" method="post">
            <div class="row g-3 mb-3 align-items-end">

                <div class="col-12 col-md-3">
                    <label class="form-label">Desde</label>
                    <input type="date" name="filterDesde" class="form-control" />
                </div>

                <div class="col-12 col-md-3">
                    <label class="form-label">Hasta</label>
                    <input type="date" name="filterHasta" class="form-control" />
                </div>

                <div class="col-12 col-md-3">
                    <label class="form-label">Condominio</label>
                    <select name="filterCondominio" class="form-select">
                        <option value="">Todos</option>
                        @foreach (var condominio in condominios)
                        {
                            <option value="@condominio.Id">@condominio.Nombre</option>
                        }
                    </select>
                </div>

                <div class="col-12 col-md-3 d-flex gap-2">
                    <button class="btn btn-outline-primary w-100">Buscar</button>
                    <a asp-action="Index" class="btn btn-outline-warning w-100">Reiniciar</a>
                </div>

            </div>
        </form>

        <div id="historialMessages" class="mb-3"></div>

        <!-- TABLA -->
        <div class="table-responsive">
            <table class="table table-hover table-bordered align-middle text-nowrap">
                <thead class="table-dark">
                    <tr>
                        <th>Contrato</th>
                        <th class="d-none d-md-table-cell">Cliente</th>
                        <th>Lote</th>
                        <th>Fecha</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center">No se encontraron ventas</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var venta in Model)
                        {
                            <tr>
                                <td>@venta.NumContrato</td>
                                <td class="d-none d-md-table-cell">@venta.CorreoCliente</td>
                                <td>@venta.CodLote</td>
                                <td>@venta.FechaDeRegistro.ToString("dd/MM/yyyy")</td>

                                <td>
                                    @if (venta.Estado == "EN PROCESO")
                                    {
                                        <span class="badge bg-warning">@venta.Estado</span>
                                    }
                                    else if (venta.Estado == "TERMINADO")
                                    {
                                        <span class="badge bg-success">@venta.Estado</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@venta.Estado</span>
                                    }
                                </td>

                                <!-- ACCIONES -->
                                <td>
                                    <div class="d-flex flex-column flex-md-row gap-2">

                                        @if (venta.Estado != "ANULADA")
                                        {
                                            @if (venta.Estado != "TERMINADO")
                                            {
                                                <button class="btn btn-danger w-100 w-md-auto"
                                                        data-numContrato="@venta.NumContrato"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#modalNulidad">
                                                    <i class="bi bi-trash-fill"></i>
                                                </button>
                                            }

                                            <a class="btn btn-success w-100 w-md-auto"
                                               onclick="GenerarComprobante(@venta.NumContrato)"
                                               data-correo="@venta.CorreoCliente"
                                               data-bs-toggle="modal"
                                               data-bs-target="#modalComprobante">
                                                Comprobante
                                            </a>
                                        }
                                        else
                                        {
                                            <a class="btn btn-danger w-100"
                                               data-numContrato="@venta.NumContrato"
                                               data-bs-toggle="modal"
                                               data-bs-target="#modalMotivoNulidad">
                                                Motivo
                                            </a>
                                        }

                                    </div>
                                </td>

                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>

<!-- MODAL COMPROBANTE -->
<div class="modal fade" id="modalComprobante" tabindex="-1">
    <div class="modal-dialog modal-lg modal-fullscreen-sm-down modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title fw-bold">Comprobante de Venta</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-2">
                <form asp-action="EnviarComprobante" method="post">
                    <input type="hidden" name="pdf" id="pdfUrl" />
                    <input type="hidden" name="correo" id="correoCliente" />

                    <iframe id="visorPDF"
                            style="width:100%; height:60vh; border:none; border-radius:8px;">
                    </iframe>

                    <div class="modal-footer mt-2">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Enviar</button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

<!-- MODAL NULIDAD -->
<div class="modal fade" id="modalNulidad" tabindex="-1">
    <div class="modal-dialog modal-lg modal-fullscreen-sm-down modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title fw-bold">Anular Venta</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-2">
                <form asp-action="AnularVenta" method="post">
                    <input type="hidden" name="numContrato" id="numContrato" />

                    <label class="form-label">Motivo</label>
                    <input type="text" class="form-control" name="motivo" required>

                    <div class="modal-footer mt-2">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-danger">Anular</button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

<!-- MODAL MOTIVO -->
<div class="modal fade" id="modalMotivoNulidad" tabindex="-1">
    <div class="modal-dialog modal-lg modal-fullscreen-sm-down modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title fw-bold">Motivo de Nulidad</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-2">
                <input type="text" class="form-control" id="motivoNulidad" readonly>

                <div class="modal-footer mt-2">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Volver</button>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function GenerarComprobante(numContrato){
            const response = await fetch(`/Ventas/GenerarComprobante?numContrato=${numContrato}`);
            const data = await response.json();
            document.getElementById("visorPDF").src = data.url;
            document.getElementById("pdfUrl").value = data.url;
        }

        document.getElementById('modalComprobante')
        .addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const correo = button.getAttribute('data-correo');
            document.getElementById("correoCliente").value = correo;
        });

        document.getElementById('modalNulidad')
        .addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const numContrato = button.getAttribute('data-numContrato');
            document.getElementById("numContrato").value = numContrato;
        });

        document.getElementById('modalMotivoNulidad')
        .addEventListener('show.bs.modal', async function (event){
            const button = event.relatedTarget;
            const numContrato = button.getAttribute('data-numContrato');
            const response = await fetch(`/Ventas/MotivoNulidad?numContrato=${numContrato}`);
            const data = await response.json();
            document.getElementById("motivoNulidad").value = data;
        });
    </script>
}