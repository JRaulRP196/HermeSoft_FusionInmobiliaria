@using HermeSoft_Fusion.Models
@using HermeSoft_Fusion.Models.Banco
@using Newtonsoft.Json

@{
    ViewBag.Title = "Registrar Venta";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<div class="row">
    <div class="col">
        <div class="card border-0 shadow-sm rounded-4 p-4">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold">Registro de Venta</h4>
                <a href="/Ventas/Index" class="btn btn-light border">
                    <i class="fas fa-arrow-left me-2"></i> Volver
                </a>
            </div>

            <form id="ventaForm" class="needs-validation" novalidate>

                <!-- ================= DATOS GENERALES ================= -->
                <div class="card border-0 shadow-sm rounded-3 p-3 mb-4">
                    <h5 class="mb-3">Datos Generales</h5>

                    <div class="row g-3">

                        <div class="col-md-4">
                            <label class="form-label">Cliente *</label>
                            <select id="cliente" class="form-select" required>
                                <option value="" selected disabled>Seleccione cliente</option>
                                <option value="juan.perez@correo.com">Juan Pérez</option>
                                <option value="ana.rodriguez@correo.com">Ana Rodríguez</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Lote *</label>
                            <input id="lote" class="form-control" value="@ViewBag.lote" readonly required />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Asesor *</label>
                            <input type="email" id="asesor" class="form-control" value="asesor.ventas@firma.com" required />
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Fecha de Venta *</label>
                            <input type="date" id="fechaVenta" class="form-control" required />
                        </div>
                        <!--
                        <div class="col-md-1">
                            <label class="form-label">Moneda *</label>
                            <select id="moneda" class="form-select" required>
                                <option value="CRC">(₡)</option>
                                <option value="USD">($)</option>
                            </select>
                        </div>
                        -->
                        <div class="col-md-2">
                            <label class="form-label">% Descuento *</label>
                            <input type="number" id="descuento" class="form-control" value="0" required />
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Banco *</label>
                            <select id="banco" class="form-select" required>
                                <option value="" selected disabled>Seleccione banco</option>
                                @foreach (var b in ViewBag.Bancos as IEnumerable<HermeSoft_Fusion.Models.Banco.Banco>)
                                {
                                    <option value="@b.IdBanco">@b.Nombre</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Escenario *</label>
                            <select id="escenario" class="form-select" required disabled>
                                <option value="">Seleccione escenario</option>
                            </select>
                        </div>

                        
                        <div class="col-md-6">
                            <label class="form-label">Plazo (meses) *</label>
                            <select id="plazoSelect" class="form-select" required disabled>
                                <option value="">Seleccione plazo</option>
                            </select>

                            
                            <input type="hidden" id="plazoMeses" />
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Tipo de asalariado *</label>
                            <select id="tipoAsalariado" class="form-select" required>
                                <option value="" selected disabled>Seleccione</option>
                                <option value="Privado">Privado</option>
                                <option value="Publico">Público</option>
                                <option value="Prof_Independiente">Profesional Independiente</option>
                                <option value="Trab_Independiente">Trabajador Independiente</option>
                            </select>
                        </div>

                    </div>
                </div>

               
                <div class="row g-4 mb-4">

                    <!-- PRIMA -->
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm rounded-3 p-3 h-100">
                            <h5>Prima</h5>

                            <div class="mb-3">
                                <label>% Prima *</label>
                                <input type="number" id="porcPrima" class="form-control" value="10" />
                            </div>

                            <div class="mb-3">
                                <label>Fecha vencimiento *</label>
                                <input type="date" id="fechaPrima" class="form-control" />
                            </div>
                        </div>
                    </div>

                    <!-- GASTOS -->
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm rounded-3 p-3 h-100">
                            <h5 class="mb-2">Gastos de Formalización</h5>

                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-2">
                                    <thead>
                                        <tr>
                                            <th>Concepto</th>
                                            <th style="width: 45%;">%</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>Seguro Vida</td>
                                            <td>
                                                <input type="number" id="porcSeguros" class="form-control" value="0" readonly />
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>Seguro Desempleado</td>
                                            <td>
                                                <input type="number" id="porcSeguros" class="form-control" value="0" readonly />
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>Honorarios abogados</td>
                                            <td>
                                                <input type="number" id="porcAbogados" class="form-control" value="0" readonly />
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>Comisión bancaria</td>
                                            <td>
                                                <input type="number" id="porcComision" class="form-control" value="0" readonly />
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>Timbre fiscal</td>
                                            <td>
                                                <input type="number" id="porcTimbre" class="form-control" value="0" readonly />
                                                <small id="msgTimbre" class="text-danger d-none">
                                                    No se encontró timbre fiscal. Ingréselo manualmente.
                                                </small>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                            <button type="button" id="calcGastoFormal" class="btn btn-outline-primary w-100">
                                Calcular gasto de formalización
                            </button>

                            <input type="text" id="gastoFormalizacion" class="form-control mt-2" readonly
                                   placeholder="Resultado gasto de formalización" />
                        </div>
                    </div>


                    <!-- CUOTA -->
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm rounded-3 p-3 h-100">
                            <h5 class="mb-2">Cuota Bancaria</h5>

                            <div class="table-responsive">
                                <table id="tablaCuotas" class="table table-sm align-middle mb-2">
                                    <thead>
                                        <tr>
                                            <th>Plazo (meses)</th>
                                            <th>Escenario</th>
                                            <th>Indicador</th>
                                            <th>% Interés</th>
                                            <th>Cuota</th>
                                        </tr>
                                    </thead>
                                    <tbody></tbody>
                                </table>
                            </div>

                            <div class="d-flex justify-content-end mt-2">
                                <button type="button" id="calcCuotaBancaria" class="btn btn-outline-primary" style="display:none;">
                                    Calcular Cuota Mensual Bancaria
                                </button>
                            </div>

                            <div class="row g-3 mt-2">
                                <div class="col-md-6">
                                    <label class="form-label">Plazo (meses)</label>
                                    <input type="number" id="plazoMesesDisplay" class="form-control" readonly />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">% Interés</label>
                                    <input type="number" id="tasaInteres" class="form-control" readonly />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Cuota Mensual</label>
                                    <input type="text" id="cuotaMensual" class="form-control" readonly />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Ingreso Neto Familiar</label>
                                    <input type="text" id="ingresoNeto" class="form-control" readonly />
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="row align-items-end mt-4">                       
                        <div class="col-md-6">
                            <div class="row g-3">                                
                                <div class="col-md-6">
                                    <label class="form-label">Moneda</label>                                    
                                    <select id="monedaSelect" class="form-select">
                                        <option value="CRC" selected>₡ Colón</option>
                                        <option value="USD">$ Dólar</option>
                                    </select>
                                </div>
                                <div class="col-md-6">                                   
                                    <input type="hidden" id="tipoCambioInput" class="form-control" readonly />
                                </div>
                            </div>
                        </div>
                       
                        <div class="col-md-6 text-end">
                            <button type="submit" class="btn btn-success">
                                Registrar Venta
                            </button>
                        </div>
                    </div>

                <div id="formMessages" class="mt-3"></div>

            </form>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/assets/js/ventas.js"></script>
    <script src="~/assets/js/calculos.js"></script>
}
