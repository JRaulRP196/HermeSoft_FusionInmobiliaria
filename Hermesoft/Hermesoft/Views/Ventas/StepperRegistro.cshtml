@using HermeSoft_Fusion.Models
@using HermeSoft_Fusion.Models.Banco
@using Newtonsoft.Json
@model Venta

@{
    ViewBag.Title = "Registrar Venta";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var primas = ViewBag.Primas as IEnumerable<HermeSoft_Fusion.Models.Primas> ?? new List<HermeSoft_Fusion.Models.Primas>();
    var bancos = ViewBag.Bancos as IEnumerable<HermeSoft_Fusion.Models.Banco.Banco> ?? new List<HermeSoft_Fusion.Models.Banco.Banco>();
    string clienteActual = ViewBag.Cliente?.ToString() ?? Model?.CorreoCliente ?? "";
    string loteActual = ViewBag.lote?.ToString() ?? Model?.CodLote ?? "";
    string idUsuario = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0";
    string correoAsesor = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
}

<div class="row">
    <div class="col">
        <div class="card border-0 shadow-sm rounded-4 p-4">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold">Registro de Venta</h4>
                <a asp-controller="Lote" asp-action="Index" class="btn btn-light border">
                    <i class="fas fa-arrow-left me-2"></i> Volver
                </a>
            </div>

            <form asp-controller="Ventas" asp-action="AgregarVenta" id="ventaForm" class="needs-validation" novalidate>

                <div class="stepper-wrapper mb-5">
                    <div class="stepper-item active" data-step="1">
                        <div class="step-counter">1</div>
                        <div class="step-name">Datos</div>
                    </div>

                    <div class="stepper-item" data-step="2">
                        <div class="step-counter">2</div>
                        <div class="step-name">Gastos</div>
                    </div>

                    <div class="stepper-item" data-step="3">
                        <div class="step-counter">3</div>
                        <div class="step-name">Cuota</div>
                    </div>

                    <div class="stepper-item" data-step="4">
                        <div class="step-counter">4</div>
                        <div class="step-name">Confirmar</div>
                    </div>
                </div>

                <div class="step-content" data-step="1">
                    <input type="hidden" asp-for="IdUsuario" value="@idUsuario" />

                    <div class="card border-0 shadow-sm rounded-3 p-3 mb-4">
                        <h5 class="mb-3">Datos Generales</h5>

                        <div class="row g-3">

                            <div class="col-md-6">
                                <label class="form-label">Cliente *</label>
                                <div class="input-group">
                                    <input type="email"
                                           id="clienteBusqueda"
                                           asp-for="CorreoCliente"
                                           class="form-control"
                                           placeholder="Correo del cliente"
                                           value="@clienteActual"
                                           required />
                                    <button type="button"
                                            id="btnBuscarPrimas"
                                            class="btn btn-outline-primary"
                                            title="Buscar primas">
                                        <i class="fas fa-search"></i>
                                    </button>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(clienteActual) && !primas.Any())
                                {
                                    <small class="text-danger">
                                        No se encontraron primas para este cliente.
                                    </small>
                                }
                                else if (!primas.Any())
                                {
                                    <small class="text-muted">
                                        Escriba el correo y presione la lupa para cargar las primas.
                                    </small>
                                }
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Prima disponible *</label>
                                @if (primas.Any())
                                {
                                    <select asp-for="IdPrima" class="form-select" required>
                                        <option value="">Seleccione una prima</option>
                                        @foreach (var prima in primas)
                                        {
                                            <option value="@prima.IdPrima">
                                                Prima #@prima.IdPrima - @prima.Porcentaje% - cierre @prima.FechaCierre.ToString("dd/MM/yyyy") - total ₡@prima.Total.ToString("N2")
                                            </option>
                                        }
                                    </select>
                                }
                                else
                                {
                                    <select asp-for="IdPrima" class="form-select" required disabled>
                                        <option value="">Seleccione una prima</option>
                                    </select>
                                }
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Lote *</label>
                                <input id="lote" asp-for="CodLote" class="form-control" value="@loteActual" readonly required />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Asesor *</label>
                                <input type="email" id="asesor" readonly class="form-control" value="@correoAsesor" required />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Banco *</label>
                                <select id="banco" asp-for="IdBanco" class="form-select" required>
                                    <option value="" selected hidden>Seleccione banco</option>
                                    @foreach (var b in bancos)
                                    {
                                        <option value="@b.IdBanco">@b.Nombre</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Escenario *</label>
                                <select id="escenario" class="form-select" required disabled>
                                    <option value="" selected hidden>Seleccione escenario</option>
                                </select>
                            </div>

                            <div class="col-md-12">
                                <label class="form-label">Tipo de asalariado *</label>
                                <select id="tipoAsalariado" class="form-select" required disabled>
                                    <option value="" selected hidden>Seleccione un tipo de asalariado</option>
                                </select>
                            </div>

                        </div>
                    </div>

                    <div class="text-end mt-3">
                        <button type="button" class="btn btn-primary next-btn">
                            Siguiente
                        </button>
                    </div>
                </div>

                <div class="step-content d-none" data-step="2">
                    <div class="col-md-12">
                        <div class="card border-0 shadow-sm rounded-3 p-3 h-100">
                            <h5 class="mb-2">Gastos de Formalización</h5>

                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-2">
                                    <thead>
                                        <tr>
                                            <th>Concepto</th>
                                            <th style="width: 45%;">%</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>Seguro Vida</td>
                                            <td>
                                                <input type="number" id="porcSeguroVida" class="form-control" readonly />
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>Seguro Desempleado</td>
                                            <td>
                                                <input type="number" id="porcSeguroDesempleo" class="form-control" readonly />
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>Honorarios abogados</td>
                                            <td>
                                                <input type="number" id="porcAbogados" class="form-control" readonly />
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>Comisión bancaria</td>
                                            <td>
                                                <input type="number" id="porcComision" class="form-control" readonly />
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>Timbre fiscal</td>
                                            <td>
                                                <input type="number" id="porcTimbre" class="form-control" readonly />
                                                <small id="msgTimbre" class="text-danger d-none">
                                                    No se encontró timbre fiscal. Ingréselo manualmente.
                                                </small>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                            <input type="number"
                                   id="gastoFormalizacion"
                                   asp-for="GastoFormalizacion"
                                   class="form-control mt-2"
                                   readonly
                                   placeholder="Resultado gasto de formalización" />
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-3">
                        <button type="button" class="btn btn-secondary prev-btn">
                            Anterior
                        </button>
                        <button type="button" class="btn btn-primary next-btn">
                            Siguiente
                        </button>
                    </div>
                </div>

                <div class="step-content d-none" data-step="3">
                    <div class="col-md-12">
                        <div class="card border-0 shadow-sm rounded-3 p-3 h-100">
                            <h5 class="mb-2">Cuota Bancaria</h5>

                            <div class="table-responsive">
                                <table id="tablaCuotas" class="table table-sm align-middle mb-2">
                                    <thead>
                                        <tr>
                                            <th>Plazo (meses)</th>
                                            <th>% Interés</th>
                                            <th>Cuota</th>
                                        </tr>
                                    </thead>
                                    <tbody id="bodyCuotas">
                                    </tbody>
                                </table>
                            </div>

                            <div class="row g-3 mt-2">
                                <div class="col-md-12">
                                    <label class="form-label">Ingreso Neto Familiar</label>
                                    <input type="text" id="ingresoNeto" class="form-control" readonly />
                                </div>
                            </div>

                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-3">
                        <button type="button" class="btn btn-secondary prev-btn">
                            Anterior
                        </button>
                        <button type="button" class="btn btn-primary next-btn">
                            Siguiente
                        </button>
                    </div>
                </div>

                <div class="step-content d-none" data-step="4">
                    <div class="row align-items-end mt-4">
                        <div class="col-md-6">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Moneda</label>
                                    <select id="monedaSelect" class="form-select">
                                        <option value="CRC" selected>₡ Colón</option>
                                        <option value="USD">$ Dólar</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <input type="hidden" id="tipoCambioInput" class="form-control" readonly />
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 text-end">
                            <button type="button" class="btn btn-secondary prev-btn">
                                Anterior
                            </button>
                            <button type="submit" class="btn btn-success"
                                    data-bs-toggle="modal"
                                    data-bs-target="#modalComprobante">
                                Registrar Venta
                            </button>
                        </div>
                    </div>

                    <div id="formMessages" class="mt-3"></div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalComprobante" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">
                    <i class="fas fa-check-circle me-2"></i>
                    Venta registrada correctamente
                </h5>

                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">
                <p class="mb-3">
                    La venta fue registrada exitosamente.
                    Puede generar el comprobante PDF para visualizarlo
                    o enviarlo por correo al cliente.
                </p>

                <div class="mb-3">
                    <button class="btn btn-primary me-2" id="btnGenerarPDF">
                        <i class="fas fa-file-pdf me-2"></i>
                        Generar PDF
                    </button>

                    <button class="btn btn-success" id="btnEnviarCorreo" disabled>
                        <i class="fas fa-envelope me-2"></i>
                        Enviar por correo
                    </button>
                </div>

                <div class="border rounded overflow-hidden">
                    <iframe id="visorPDF"
                            style="width:100%; height:600px; border:none;">
                    </iframe>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/assets/js/stepper.js"></script>
    <script src="~/assets/js/ventaStepper.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const btnBuscar = document.getElementById("btnBuscarPrimas");
            const inputCliente = document.getElementById("clienteBusqueda");
            const inputLote = document.getElementById("lote");

            if (btnBuscar && inputCliente && inputLote) {
                btnBuscar.addEventListener("click", function () {
                    const cliente = inputCliente.value.trim();
                    const lote = inputLote.value.trim();

                    if (!cliente) {
                        inputCliente.focus();
                        return;
                    }

                    const baseUrl = '@Url.Action("StepperRegistro", "Ventas")';
                    const url = `${baseUrl}?lote=${encodeURIComponent(lote)}&cliente=${encodeURIComponent(cliente)}`;
                    window.location.href = url;
                });
            }
        });
    </script>
}