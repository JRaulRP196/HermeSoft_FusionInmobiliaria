@using HermeSoft_Fusion.Models.Usuarios
@{
    ViewData["Title"] = "Usuarios";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model HermeSoft_Fusion.Models.Usuarios.Usuario

<div class="container-fluid py-4">

    <!-- Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="mb-1">Usuarios</h2>
            <p class="text-muted mb-0">Administra los accesos del sistema</p>
        </div>

        <button type="button"
                class="btn btn-primary px-4"
                data-bs-toggle="modal"
                data-bs-target="#modalNuevoUsuario">
            <i class="bi bi-plus-circle"></i>  Nuevo Usuario
        </button>
    </div>

    <!-- Mensajes -->
    <div class="card shadow-sm mb-4 border-0">
        @if (TempData["MensajeError"] != null)
        {
            <div class="alert alert-danger">@TempData["MensajeError"]</div>
        }

        @if (TempData["MensajeExito"] != null)
        {
            <div class="alert alert-success">@TempData["MensajeExito"]</div>
        }
    </div>

    <!-- Tabla -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 text-nowrap">

                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Usuario</th>
                            <th class="d-none d-md-table-cell">Rol</th>
                            <th>Estado</th>
                            <th class="d-none d-lg-table-cell">Correo</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (Usuario user in ViewBag.Usuarios)
                        {
                            <tr>

                                <!-- Usuario -->
                                <td class="ps-4">
                                    <div class="fw-semibold">
                                        @user.Nombre @user.Apellido1 @user.Apellido2
                                    </div>

                                    <!-- Info en móvil -->
                                    <div class="d-md-none">
                                        <small class="text-muted d-block">@user.Rol.Nombre</small>
                                        <small class="text-muted d-block">@user.Correo</small>
                                    </div>
                                </td>

                                <!-- Rol -->
                                <td class="d-none d-md-table-cell">
                                    @user.Rol.Nombre
                                </td>

                                <!-- Estado -->
                                <td>
                                    @if (user.Estado)
                                    {
                                        <span class="badge bg-success rounded-pill px-3 py-2">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger rounded-pill px-3 py-2">Inactivo</span>
                                    }
                                </td>

                                <!-- Correo -->
                                <td class="d-none d-lg-table-cell">
                                    @user.Correo
                                </td>

                                <!-- Acciones -->
                                <td>
                                    <div class="d-flex flex-column flex-md-row gap-2">
                                        <button class="btn btn-light border btn-editar w-100 w-md-auto"
                                                data-id="@user.IdUsuario">
                                            <i class="ri-pencil-line"></i> Editar
                                        </button>
                                    </div>
                                </td>

                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        </div>
    </div>

</div>


<!-- Modal: Nuevo Usuario -->
<div class="modal fade" id="modalNuevoUsuario" tabindex="-1" aria-labelledby="modalNuevoUsuarioLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Nuevo usuario</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">

                <form asp-action="Agregar" method="post" class="needs-validation" novalidate>
                    <div class="row g-3">

                        <div class="col-md-6">
                            <label class="form-label">Nombre</label>
                            <input type="text" class="form-control" placeholder="Nombre" asp-for="Nombre" required>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Primer Apellido</label>
                            <input type="text" class="form-control" placeholder="Primer Apellido" asp-for="Apellido1" required>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Segundo Apellido</label>
                            <input type="text" class="form-control" placeholder="Segundo Apellido" asp-for="Apellido2" required>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Correo</label>
                            <input type="email" class="form-control" placeholder="Correo" asp-for="Correo" required>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Rol</label>
                            <select class="form-select" asp-for="IdRol" required>
                                @foreach (Rol rol in ViewBag.Roles)
                                {
                                    <option value="@rol.IdRol">@rol.Nombre</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Estado</label>
                            <select class="form-select" asp-for="Estado" required>
                                <option value="true">Activo</option>
                                <option value="false">Inactivo</option>
                            </select>
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal"><i class="bi bi-x-circle"></i> Cancelar</button>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Registrar usuario</button>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>

<!-- Modal Editar (igual que el tuyo, no modificado) -->
<div class="modal fade" id="modalEditarUsuario" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Editar usuario</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="Editar" method="post" class="needs-validation" novalidate>
                    <input type="hidden" id="IdUsuario" asp-for="IdUsuario" />
                    <input type="hidden" id="Correo" asp-for="Correo" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Nombre</label>
                            <input class="form-control" placeholder="Nombre" asp-for="Nombre" required>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Primer Apellido</label>
                            <input class="form-control" placeholder="Primer Apellido" asp-for="Apellido1" required>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label">Segundo Apellido</label>
                            <input class="form-control" placeholder="Segundo Apellido" asp-for="Apellido2" required>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Rol</label>
                            <select class="form-select" asp-for="IdRol">
                                @foreach (Rol rol in ViewBag.Roles)
                                {
                                    <option value="@rol.IdRol">@rol.Nombre</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Estado</label>
                            <select class="form-select" asp-for="Estado">
                                <option value="true">Activo</option>
                                <option value="false">Inactivo</option>
                            </select>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-light" data-bs-dismiss="modal"><i class="bi bi-x-circle"></i> Cancelar</button>
                        <button class="btn btn-primary"><i class="bi bi-save"></i> Guardar Usuario</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/assets/libs/parsleyjs/parsley.min.js"></script>
    <script src="~/assets/js/pages/form-validation.init.js"></script>
    <script src="~/assets/js/editarUsuario.js"></script>
}