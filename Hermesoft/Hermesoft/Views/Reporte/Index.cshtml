@{
    ViewData["Title"] = "Reportes";
    Layout = "~/Views/Shared/_Layout.cshtml"; 
}

<div class="container-fluid py-3 py-md-4">

    <!-- Selector de Condominios -->
    <div class="card border-0 shadow-sm rounded-4 mb-4 p-3">
        <div class="d-flex flex-column flex-md-row align-items-center gap-3">

            <!-- Botones + Nombre -->
            <div class="d-flex align-items-center justify-content-between w-100">

                <button id="btnPrevCondominio"
                        class="btn btn-outline-primary rounded-pill px-3">
                    <i class="fas fa-chevron-left"></i>
                </button>

                <h5 id="nombreCondominio"
                    class="fw-bold mb-0 text-center flex-grow-1 mx-2 text-truncate">
                    Nombre Condominio
                </h5>

                <button id="btnNextCondominio"
                        class="btn btn-outline-primary rounded-pill px-3">
                    <i class="fas fa-chevron-right"></i>
                </button>

            </div>

        </div>
    </div>

    <!-- Card principal -->
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4">

            <div class="card-header border-0 d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 px-3 px-md-4 pt-3 pt-md-4">

                <h5 class="mb-0 fw-semibold">Condominio</h5>

                <div class="d-flex flex-column flex-sm-row align-items-stretch align-items-sm-center gap-2 ms-md-auto" id="opciones">

                    <select class="form-select w-100 w-sm-auto"
                            style="min-width: 180px; max-width: 220px;"
                            id="filtro"
                            onchange="habilitarDescarga()">
                        <option value="-1" hidden selected>Filtros</option>
                        <option value="Ventas_Mes">Ventas Mes</option>
                        <option value="Disponibilidad">Disponibilidad</option>
                    </select>

                    <button class="btn btn-outline-secondary px-3 d-none"
                            style="min-width: 140px;"
                            id="btnDescargar">
                        <i class="bi bi-download"></i> Descargar
                    </button>

                </div>

            </div>

            <!-- Mapa -->
            <div class="card-body p-2 p-md-3">
                <div id="map"
                     class="w-100 rounded-3 position-relative"
                     style="height: 65vh; min-height: 450px;">

                    <div class="alert alert-danger d-none position-absolute top-50 start-50 translate-middle text-center"
                         id="error">
                        No hay mapa configurado
                    </div>

                </div>
            </div>

        </div>
    </div>

</div>

@section scripts{
    <script src="~/assets/js/reporte.js"></script>
    <script src="~/assets/js/app.js"></script>
    <script>
        function habilitarDescarga(){
            descargarBtn = document.getElementById('btnDescargar');
            descargarBtn.classList.remove("d-none");
        }

    </script>
    <script src="https://unpkg.com/leaflet-image/leaflet-image.js"></script>
}